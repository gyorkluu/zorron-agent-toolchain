{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ports-registry",
  "description": "Centralized port registry for all local development projects. Store this file on a remote HTTP server (GitHub Gist, GitHub raw, S3, etc.) so all agents and tools can fetch it.",
  "version": "1.0.0",
  "lastUpdated": "2026-05-12",
  "reservedSystemPorts": {
    "ssh": { "port": 22, "protocol": "TCP", "service": "SSH", "note": "Secure Shell" },
    "ftp": { "port": 21, "protocol": "TCP", "service": "FTP", "note": "File Transfer Protocol" },
    "smtp": { "port": 25, "protocol": "TCP", "service": "SMTP", "note": "Simple Mail Transfer Protocol" },
    "dns": { "port": 53, "protocol": "TCP/UDP", "service": "DNS", "note": "Domain Name System" },
    "http": { "port": 80, "protocol": "TCP", "service": "HTTP", "note": "Hypertext Transfer Protocol" },
    "pop3": { "port": 110, "protocol": "TCP", "service": "POP3", "note": "Post Office Protocol v3" },
    "ntp": { "port": 123, "protocol": "UDP", "service": "NTP", "note": "Network Time Protocol" },
    "imap": { "port": 143, "protocol": "TCP", "service": "IMAP", "note": "Internet Message Access Protocol" },
    "https": { "port": 443, "protocol": "TCP", "service": "HTTPS", "note": "HTTP over TLS/SSL" },
    "smtps": { "port": 465, "protocol": "TCP", "service": "SMTPS", "note": "SMTP over SSL" },
    "syslog": { "port": 514, "protocol": "UDP", "service": "Syslog", "note": "System Log" },
    "smtp-submit": { "port": 587, "protocol": "TCP", "service": "SMTP-Submit", "note": "SMTP Message Submission" },
    "ldaps": { "port": 636, "protocol": "TCP", "service": "LDAPS", "note": "LDAP over SSL" },
    "imaps": { "port": 993, "protocol": "TCP", "service": "IMAPS", "note": "IMAP over SSL" },
    "pop3s": { "port": 995, "protocol": "TCP", "service": "POP3S", "note": "POP3 over SSL" },
    "mysql": { "port": 3306, "protocol": "TCP", "service": "MySQL", "note": "MySQL Database" },
    "rdp": { "port": 3389, "protocol": "TCP", "service": "RDP", "note": "Remote Desktop Protocol" },
    "postgresql": { "port": 5432, "protocol": "TCP", "service": "PostgreSQL", "note": "PostgreSQL Database" },
    "mongodb": { "port": 27017, "protocol": "TCP", "service": "MongoDB", "note": "MongoDB Database" },
    "mongodb-web": { "port": 28017, "protocol": "TCP", "service": "MongoDB-Web", "note": "MongoDB Web Interface" },
    "redis": { "port": 6379, "protocol": "TCP", "service": "Redis", "note": "Redis Key-Value Store" },
    "redis-cluster": { "port": 16379, "protocol": "TCP", "service": "Redis-Cluster", "note": "Redis Cluster Bus" },
    "elasticsearch": { "port": 9200, "protocol": "TCP", "service": "Elasticsearch-HTTP", "note": "Elasticsearch REST API" },
    "elasticsearch-transport": { "port": 9300, "protocol": "TCP", "service": "Elasticsearch-Transport", "note": "Elasticsearch Transport" },
    "kibana": { "port": 5601, "protocol": "TCP", "service": "Kibana", "note": "Kibana Dashboard" },
    "rabbitmq": { "port": 5672, "protocol": "TCP", "service": "RabbitMQ-AMQP", "note": "RabbitMQ AMQP" },
    "rabbitmq-mgmt": { "port": 15672, "protocol": "TCP", "service": "RabbitMQ-Mgmt", "note": "RabbitMQ Management UI" },
    "kafka": { "port": 9092, "protocol": "TCP", "service": "Kafka", "note": "Apache Kafka Broker" },
    "zookeeper": { "port": 2181, "protocol": "TCP", "service": "ZooKeeper", "note": "Apache ZooKeeper" },
    "cassandra": { "port": 9042, "protocol": "TCP", "service": "Cassandra", "note": "Apache Cassandra" },
    "memcached": { "port": 11211, "protocol": "TCP", "service": "Memcached", "note": "Memcached" },
    "minio": { "port": 9000, "protocol": "TCP", "service": "MinIO-API", "note": "MinIO Object Storage API" },
    "minio-console": { "port": 9001, "protocol": "TCP", "service": "MinIO-Console", "note": "MinIO Console UI" },
    "consul": { "port": 8500, "protocol": "TCP", "service": "Consul-HTTP", "note": "Consul HTTP API" },
    "etcd": { "port": 2379, "protocol": "TCP", "service": "etcd", "note": "etcd Client" },
    "nats": { "port": 4222, "protocol": "TCP", "service": "NATS", "note": "NATS Messaging" },
    "grafana": { "port": 3000, "protocol": "TCP", "service": "Grafana", "note": "Grafana Dashboard (default)" },
    "prometheus": { "port": 9090, "protocol": "TCP", "service": "Prometheus", "note": "Prometheus Metrics" },
    "jenkins": { "port": 8080, "protocol": "TCP", "service": "Jenkins", "note": "Jenkins CI/CD" },
    "docker-registry": { "port": 5000, "protocol": "TCP", "service": "Docker-Registry", "note": "Docker Registry" },
    "mailhog-smtp": { "port": 1025, "protocol": "TCP", "service": "MailHog-SMTP", "note": "MailHog SMTP" },
    "mailhog-web": { "port": 8025, "protocol": "TCP", "service": "MailHog-Web", "note": "MailHog Web UI" },
    "adminer": { "port": 8080, "protocol": "TCP", "service": "Adminer", "note": "Adminer DB Management" },
    "pgadmin": { "port": 5050, "protocol": "TCP", "service": "pgAdmin", "note": "PostgreSQL Admin" },
    "mailpit-smtp": { "port": 1025, "protocol": "TCP", "service": "Mailpit-SMTP", "note": "Mailpit SMTP" },
    "mailpit-web": { "port": 8025, "protocol": "TCP", "service": "Mailpit-Web", "note": "Mailpit Web UI" }
  },
  "projectPorts": [
    {
      "project": "zorron-nest",
      "location": "~/Documents/zorronAgents/zorron-agents/zorron-nest",
      "ports": [
        { "port": 3000, "service": "API Gateway", "protocol": "HTTP" },
        { "port": 3001, "service": "Dispatcher", "protocol": "HTTP" },
        { "port": 3002, "service": "Leader Worker", "protocol": "HTTP" },
        { "port": 3003, "service": "NestJS Main", "protocol": "HTTP" },
        { "port": 5173, "service": "Vue Dashboard (Vite Dev)", "protocol": "HTTP" }
      ]
    }
  ],
  "portRanges": {
    "development": { "start": 3000, "end": 3999, "note": "General development servers" },
    "viteDev": { "start": 5173, "end": 5199, "note": "Vite dev servers (5173 default)" },
    "nextDev": { "start": 3000, "end": 3099, "note": "Next.js dev servers" },
    "nestDev": { "start": 3100, "end": 3199, "note": "NestJS dev servers" },
    "elysiaDev": { "start": 3200, "end": 3299, "note": "ElysiaJS dev servers" },
    "reactDev": { "start": 3000, "end": 3009, "note": "React/CRA dev servers" },
    "angularDev": { "start": 4200, "end": 4299, "note": "Angular dev servers" },
    "vueDev": { "start": 8080, "end": 8089, "note": "Vue CLI dev servers" },
    "webpackDev": { "start": 8080, "end": 8099, "note": "Webpack dev servers" },
    "storybook": { "start": 6006, "end": 6099, "note": "Storybook" },
    "strapi": { "start": 1337, "end": 1349, "note": "Strapi CMS" },
    "hasura": { "start": 8080, "end": 8089, "note": "Hasura GraphQL Engine" },
    "supabase": { "start": 54321, "end": 54330, "note": "Supabase local" },
    "dynamodb-local": { "start": 8000, "end": 8009, "note": "DynamoDB Local" }
  }
}
